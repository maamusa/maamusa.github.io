---
// src/components/PostControls.astro
---
<div class="flex items-center gap-2" id="post-controls">
  <button id="btn-translate" title="Translate to Hindi" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-white/10 transition-colors text-sm font-serif">
    <span id="translate-icon">अ</span>
  </button>
  
  <button id="btn-audio-toggle" title="Play Audio" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-white/10 transition-colors">
    <svg id="icon-play" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
    <svg id="icon-pause" class="hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
  </button>
</div>

<script>
  const translateBtn = document.getElementById('btn-translate');
  const translateIconEl = document.getElementById('translate-icon');
  const audioToggleBtn = document.getElementById('btn-audio-toggle');
  const iconPlay = document.getElementById('icon-play');
  const iconPause = document.getElementById('icon-pause');
  
  let currentLang = 'en';
  let originalHtml = ''; 
  let isPlaying = false;
  
  async function translateText(text: string, targetLang: string): Promise<string> {
    if(!text.trim()) return text;
    try {
      const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;
      const res = await fetch(url);
      const data = await res.json();
      return data[0].map((x: any) => x[0]).join('');
    } catch(e) {
      console.error("Translation error", e);
      return text;
    }
  }

  function stopAudio() {
    window.speechSynthesis.cancel();
    isPlaying = false;
    if (iconPlay) iconPlay.classList.remove('hidden');
    if (iconPause) iconPause.classList.add('hidden');
  }

  async function toggleTranslate() {
    const article = document.querySelector('article');
    if(!article) return;
    
    stopAudio();
    
    if (currentLang === 'en') {
      if (!originalHtml) {
        originalHtml = article.innerHTML;
      }
      
      if (translateIconEl) {
        translateIconEl.style.animation = 'pulse 1.5s infinite';
      }
      if (translateBtn) {
        translateBtn.title = 'Translating...';
        translateBtn.style.pointerEvents = 'none';
      }
      
      const textNodes: Node[] = [];
      const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
        acceptNode: function(node) {
          const parent = node.parentNode as HTMLElement;
          if (parent && (parent.nodeName === 'CODE' || parent.nodeName === 'PRE')) return NodeFilter.FILTER_REJECT;
          if (node.nodeValue && !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      });
      
      let node;
      while ((node = walker.nextNode())) {
        textNodes.push(node);
      }
      
      const delay = (ms: number) => new Promise(res => setTimeout(res, ms));
      const batchSize = 10;
      for (let i = 0; i < textNodes.length; i += batchSize) {
        const batch = textNodes.slice(i, i + batchSize);
        await Promise.all(batch.map(async (n) => {
          if (n.nodeValue) {
            n.nodeValue = await translateText(n.nodeValue, 'hi');
          }
        }));
        await delay(300);
      }
      
      currentLang = 'hi';
      if (translateIconEl) {
        translateIconEl.innerText = 'En';
        translateIconEl.style.animation = 'none';
        translateIconEl.className = 'font-sans text-xs font-semibold';
      }
      if (translateBtn) {
        translateBtn.title = 'View in English';
        translateBtn.style.pointerEvents = 'auto';
      }
      
    } else {
      article.innerHTML = originalHtml;
      currentLang = 'en';
      if (translateIconEl) {
        translateIconEl.innerText = 'अ';
        translateIconEl.className = '';
      }
      if (translateBtn) translateBtn.title = 'Translate to Hindi';
    }
  }

  translateBtn?.addEventListener('click', toggleTranslate);

  function toggleAudio() {
    if (isPlaying) {
      stopAudio();
      return;
    }

    const article = document.querySelector('article');
    if(!article) return;
    
    const textToSpeak = article.innerText; 
    const utterance = new SpeechSynthesisUtterance(textToSpeak);
    utterance.lang = currentLang === 'hi' ? 'hi-IN' : 'en-US';
    
    utterance.onstart = () => {
      isPlaying = true;
      if (iconPlay) iconPlay.classList.add('hidden');
      if (iconPause) iconPause.classList.remove('hidden');
    };
    utterance.onend = stopAudio;
    utterance.onerror = stopAudio;
    
    window.speechSynthesis.speak(utterance);
  }

  audioToggleBtn?.addEventListener('click', toggleAudio);

</script>
<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .5; }
  }
</style>
