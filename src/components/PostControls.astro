---
// src/components/PostControls.astro
---
<div class="flex flex-wrap gap-2 mb-8 items-center opacity-60 hover:opacity-100 transition-opacity" id="post-controls">
  <button id="btn-translate" title="Translate to Hindi" class="w-8 h-8 rounded-full bg-white/5 hover:bg-white/10 text-sm transition-colors flex items-center justify-center">
    <span id="translate-icon">🌐</span>
  </button>
  <button id="btn-audio-en" title="Play Audio (English)" class="w-8 h-8 rounded-full bg-white/5 hover:bg-white/10 text-sm transition-colors flex items-center justify-center">
    <span>🔊</span>
  </button>
  <button id="btn-audio-hi" title="Play Audio (Hindi)" class="w-8 h-8 rounded-full bg-white/5 hover:bg-white/10 text-sm transition-colors flex items-center justify-center" style="display: none;">
    <span>🔊</span>
  </button>
  <button id="btn-stop-audio" title="Stop Audio" class="w-8 h-8 rounded-full bg-red-500/10 hover:bg-red-500/20 text-sm transition-colors flex items-center justify-center" style="display: none;">
    <span>⏹</span>
  </button>
</div>

<script>
  const translateBtn = document.getElementById('btn-translate');
  const translateIconEl = document.getElementById('translate-icon');
  const playEnBtn = document.getElementById('btn-audio-en');
  const playHiBtn = document.getElementById('btn-audio-hi');
  const stopAudioBtn = document.getElementById('btn-stop-audio');
  
  let currentLang = 'en';
  let originalHtml = ''; 
  
  async function translateText(text: string, targetLang: string): Promise<string> {
    if(!text.trim()) return text;
    try {
      const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;
      const res = await fetch(url);
      const data = await res.json();
      return data[0].map((x: any) => x[0]).join('');
    } catch(e) {
      console.error("Translation error", e);
      return text;
    }
  }

  async function toggleTranslate() {
    const article = document.querySelector('article');
    if(!article) return;
    
    if (currentLang === 'en') {
      if (!originalHtml) {
        originalHtml = article.innerHTML;
      }
      
      if (translateBtn) {
        translateBtn.title = 'Translating...';
        translateBtn.style.opacity = '0.5';
        translateBtn.style.pointerEvents = 'none';
      }
      
      const textNodes: Node[] = [];
      const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
        acceptNode: function(node) {
          const parent = node.parentNode as HTMLElement;
          if (parent && (parent.nodeName === 'CODE' || parent.nodeName === 'PRE')) return NodeFilter.FILTER_REJECT;
          if (node.nodeValue && !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      });
      
      let node;
      while ((node = walker.nextNode())) {
        textNodes.push(node);
      }
      
      const delay = (ms: number) => new Promise(res => setTimeout(res, ms));
      const batchSize = 10;
      for (let i = 0; i < textNodes.length; i += batchSize) {
        const batch = textNodes.slice(i, i + batchSize);
        await Promise.all(batch.map(async (n) => {
          if (n.nodeValue) {
            n.nodeValue = await translateText(n.nodeValue, 'hi');
          }
        }));
        await delay(300);
      }
      
      currentLang = 'hi';
      if (translateIconEl) translateIconEl.innerText = '🇬🇧';
      if (translateBtn) {
        translateBtn.title = 'View in English';
        translateBtn.style.opacity = '1';
        translateBtn.style.pointerEvents = 'auto';
      }
      
      if (playEnBtn) playEnBtn.style.display = 'none';
      if (playHiBtn) playHiBtn.style.display = 'flex';
      
    } else {
      article.innerHTML = originalHtml;
      currentLang = 'en';
      if (translateIconEl) translateIconEl.innerText = '🌐';
      if (translateBtn) translateBtn.title = 'Translate to Hindi';
      if (playEnBtn) playEnBtn.style.display = 'flex';
      if (playHiBtn) playHiBtn.style.display = 'none';
    }
  }

  translateBtn?.addEventListener('click', toggleTranslate);

  function speak(lang: string) {
    window.speechSynthesis.cancel();
    const article = document.querySelector('article');
    if(!article) return;
    
    const textToSpeak = article.innerText; 
    const utterance = new SpeechSynthesisUtterance(textToSpeak);
    utterance.lang = lang === 'hi' ? 'hi-IN' : 'en-US';
    
    utterance.onstart = () => {
      if (stopAudioBtn) stopAudioBtn.style.display = 'flex';
    };
    utterance.onend = () => {
      if (stopAudioBtn) stopAudioBtn.style.display = 'none';
    };
    utterance.onerror = () => {
      if (stopAudioBtn) stopAudioBtn.style.display = 'none';
    };
    
    window.speechSynthesis.speak(utterance);
  }

  playEnBtn?.addEventListener('click', () => speak('en'));
  playHiBtn?.addEventListener('click', () => speak('hi'));
  stopAudioBtn?.addEventListener('click', () => {
    window.speechSynthesis.cancel();
    if (stopAudioBtn) stopAudioBtn.style.display = 'none';
  });
</script>
