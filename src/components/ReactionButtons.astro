---
// src/components/ReactionButtons.astro
interface Props {
  pageId: string;
}
const { pageId } = Astro.props;
---

<div class="flex items-center gap-4 mt-12 mb-4 pt-8 border-t border-white/10" id="reaction-container" data-page-id={pageId}>
  <p class="opacity-60 text-sm font-medium">Was this helpful?</p>
  <div class="flex items-center gap-2">
    <button id="btn-upvote" class="w-10 h-10 flex items-center justify-center rounded-full border border-white/10 hover:bg-white/5 transition-colors opacity-60 hover:opacity-100" title="Upvote">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    </button>
    <span id="vote-count" class="font-bold text-sm w-4 text-center">0</span>
    <button id="btn-downvote" class="w-10 h-10 flex items-center justify-center rounded-full border border-white/10 hover:bg-white/5 transition-colors opacity-60 hover:opacity-100" title="Downvote">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </button>
  </div>
</div>

<script>
  // Ensure the script runs on client side after Astro page load
  document.addEventListener('DOMContentLoaded', initReactions);
  document.addEventListener('astro:page-load', initReactions); // For ViewTransitions

  function initReactions() {
    const container = document.getElementById('reaction-container');
    const btnUpvote = document.getElementById('btn-upvote');
    const btnDownvote = document.getElementById('btn-downvote');
    const voteCount = document.getElementById('vote-count');
    
    if (container && btnUpvote && btnDownvote && voteCount) {
      const pageId = container.getAttribute('data-page-id');
      const storageKey = `vote_${pageId}`;
      
      // Mock initial count since we have no backend yet
      let count = Math.floor(Math.random() * 50) + 10;
      
      const userVote = localStorage.getItem(storageKey);
      if (userVote === 'up') {
        count += 1;
        btnUpvote.classList.add('bg-white/10', 'text-blue-300', '!opacity-100', 'border-blue-300/30');
      } else if (userVote === 'down') {
        count -= 1;
        btnDownvote.classList.add('bg-white/10', 'text-red-300', '!opacity-100', 'border-red-300/30');
      }
      
      voteCount.innerText = count.toString();
      
      function handleVote(type: 'up' | 'down') {
        const currentVote = localStorage.getItem(storageKey);
        
        if (currentVote === type) {
          // Remove vote
          localStorage.removeItem(storageKey);
          count = type === 'up' ? count - 1 : count + 1;
          btnUpvote?.classList.remove('bg-white/10', 'text-blue-300', '!opacity-100', 'border-blue-300/30');
          btnDownvote?.classList.remove('bg-white/10', 'text-red-300', '!opacity-100', 'border-red-300/30');
        } else {
          // Change or add vote
          localStorage.setItem(storageKey, type);
          
          if (currentVote === 'up') {
            count -= 2; // from +1 to -1
          } else if (currentVote === 'down') {
            count += 2; // from -1 to +1
          } else {
            count = type === 'up' ? count + 1 : count - 1;
          }
          
          btnUpvote?.classList.remove('bg-white/10', 'text-blue-300', '!opacity-100', 'border-blue-300/30');
          btnDownvote?.classList.remove('bg-white/10', 'text-red-300', '!opacity-100', 'border-red-300/30');
          
          if (type === 'up') {
            btnUpvote?.classList.add('bg-white/10', 'text-blue-300', '!opacity-100', 'border-blue-300/30');
          } else {
            btnDownvote?.classList.add('bg-white/10', 'text-red-300', '!opacity-100', 'border-red-300/30');
          }
        }
        
        if (voteCount) voteCount.innerText = count.toString();
      }
      
      btnUpvote.onclick = () => handleVote('up');
      btnDownvote.onclick = () => handleVote('down');
    }
  }
  
  // Call once in case the events already fired
  initReactions();
</script>
