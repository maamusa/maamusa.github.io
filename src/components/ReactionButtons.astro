---
// src/components/ReactionButtons.astro
interface Props {
  pageId: string;
}
const { pageId } = Astro.props;
---

<div class="flex items-center rounded-md border border-neutral-500/30 text-sm overflow-hidden" id="reaction-container" data-page-id={pageId}>
  <button id="btn-upvote" class="w-7 h-7 flex items-center justify-center hover:bg-neutral-500/20 transition-colors opacity-70 hover:opacity-100" title="Upvote">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>
  <span id="vote-count" class="font-serif opacity-70 px-1 text-center min-w-[2ch]">0</span>
  <button id="btn-downvote" class="w-7 h-7 flex items-center justify-center hover:bg-neutral-500/20 transition-colors opacity-70 hover:opacity-100" title="Downvote">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </button>
</div>

<script type="module">
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

  // Initialize Supabase
  const supabaseUrl = 'https://ngqoeawdbbiiikeugyje.supabase.co'
  const supabaseKey = 'sb_publishable_GacueCXO5sNHwgiKwH5Mrg_Z22HO6LA'
  const supabase = createClient(supabaseUrl, supabaseKey)

  function initReactions() {
    const container = document.getElementById('reaction-container');
    const btnUpvote = document.getElementById('btn-upvote');
    const btnDownvote = document.getElementById('btn-downvote');
    const voteCount = document.getElementById('vote-count');
    
    if (container && btnUpvote && btnDownvote && voteCount) {
      const pageId = container.getAttribute('data-page-id');
      const storageKey = `vote_${pageId}`;
      let currentGlobalCount = 0;
      
      // Load user's local vote state
      const userVote = localStorage.getItem(storageKey);
      if (userVote === 'up') {
        btnUpvote.classList.add('bg-neutral-500/30', '!opacity-100');
      } else if (userVote === 'down') {
        btnDownvote.classList.add('bg-neutral-500/30', '!opacity-100');
      }

      // Fetch global vote count from Supabase
      async function fetchGlobalCount() {
        try {
          const { data, error } = await supabase
            .from('page_votes')
            .select('vote_count')
            .eq('page_id', pageId)
            .single();
            
          if (data) {
            currentGlobalCount = data.vote_count;
            voteCount.innerText = currentGlobalCount.toString();
          }
        } catch (e) {
          console.error('Error fetching votes', e);
        }
      }
      fetchGlobalCount();
      
      async function handleVote(type) {
        const currentVote = localStorage.getItem(storageKey);
        let increment = 0;
        
        if (currentVote === type) {
          // Remove vote
          localStorage.removeItem(storageKey);
          increment = type === 'up' ? -1 : 1;
          btnUpvote.classList.remove('bg-neutral-500/30', '!opacity-100');
          btnDownvote.classList.remove('bg-neutral-500/30', '!opacity-100');
        } else {
          // Change or add vote
          localStorage.setItem(storageKey, type);
          
          if (currentVote === 'up') increment = -2; // from +1 to -1
          else if (currentVote === 'down') increment = 2; // from -1 to +1
          else increment = type === 'up' ? 1 : -1;
          
          btnUpvote.classList.remove('bg-neutral-500/30', '!opacity-100');
          btnDownvote.classList.remove('bg-neutral-500/30', '!opacity-100');
          
          if (type === 'up') btnUpvote.classList.add('bg-neutral-500/30', '!opacity-100');
          else btnDownvote.classList.add('bg-neutral-500/30', '!opacity-100');
        }
        
        // Optimistic UI update
        currentGlobalCount += increment;
        voteCount.innerText = currentGlobalCount.toString();
        
        // Send to Supabase via our secure RPC function
        try {
          await supabase.rpc('vote', { page_id_arg: pageId, inc_arg: increment });
        } catch (e) {
          console.error('Error recording vote', e);
        }
      }
      
      btnUpvote.onclick = () => handleVote('up');
      btnDownvote.onclick = () => handleVote('down');
    }
  }
  
  document.addEventListener('DOMContentLoaded', initReactions);
  document.addEventListener('astro:page-load', initReactions);
</script>
