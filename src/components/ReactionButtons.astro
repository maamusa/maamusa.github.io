---
// src/components/ReactionButtons.astro
interface Props {
  pageId: string;
}
const { pageId } = Astro.props;
---

<div class="flex items-center gap-1" id="reaction-container" data-page-id={pageId}>
  <button id="btn-upvote" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-neutral-500/20 transition-colors opacity-60 hover:opacity-100" title="Upvote">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>
  <span id="vote-count" class="font-serif text-sm opacity-60 min-w-[1ch] text-center">0</span>
  <button id="btn-downvote" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-neutral-500/20 transition-colors opacity-60 hover:opacity-100" title="Downvote">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </button>
</div>

<script>
  // Ensure the script runs on client side after Astro page load
  document.addEventListener('DOMContentLoaded', initReactions);
  document.addEventListener('astro:page-load', initReactions); // For ViewTransitions

  function initReactions() {
    const container = document.getElementById('reaction-container');
    const btnUpvote = document.getElementById('btn-upvote');
    const btnDownvote = document.getElementById('btn-downvote');
    const voteCount = document.getElementById('vote-count');
    
    if (container && btnUpvote && btnDownvote && voteCount) {
      const pageId = container.getAttribute('data-page-id');
      const storageKey = `vote_${pageId}`;
      
      // Start count at 0
      let count = 0;
      
      const userVote = localStorage.getItem(storageKey);
      if (userVote === 'up') {
        count += 1;
        btnUpvote.classList.add('bg-blue-500/20', 'text-blue-400', '!opacity-100');
      } else if (userVote === 'down') {
        count -= 1;
        btnDownvote.classList.add('bg-red-500/20', 'text-red-400', '!opacity-100');
      }
      
      voteCount.innerText = count.toString();
      
      function handleVote(type: 'up' | 'down') {
        const currentVote = localStorage.getItem(storageKey);
        
        if (currentVote === type) {
          // Remove vote
          localStorage.removeItem(storageKey);
          count = type === 'up' ? count - 1 : count + 1;
          btnUpvote?.classList.remove('bg-blue-500/20', 'text-blue-400', '!opacity-100');
          btnDownvote?.classList.remove('bg-red-500/20', 'text-red-400', '!opacity-100');
        } else {
          // Change or add vote
          localStorage.setItem(storageKey, type);
          
          if (currentVote === 'up') {
            count -= 2; // from +1 to -1
          } else if (currentVote === 'down') {
            count += 2; // from -1 to +1
          } else {
            count = type === 'up' ? count + 1 : count - 1;
          }
          
          btnUpvote?.classList.remove('bg-blue-500/20', 'text-blue-400', '!opacity-100');
          btnDownvote?.classList.remove('bg-red-500/20', 'text-red-400', '!opacity-100');
          
          if (type === 'up') {
            btnUpvote?.classList.add('bg-blue-500/20', 'text-blue-400', '!opacity-100');
          } else {
            btnDownvote?.classList.add('bg-red-500/20', 'text-red-400', '!opacity-100');
          }
        }
        
        if (voteCount) voteCount.innerText = count.toString();
      }
      
      btnUpvote.onclick = () => handleVote('up');
      btnDownvote.onclick = () => handleVote('down');
    }
  }
  
  // Call once in case the events already fired
  initReactions();
</script>
