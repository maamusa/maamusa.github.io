---
import { Icon } from "astro-icon/components";
import { navBarLinks, socialLinks } from "../config";
---

<button
  id="cmd-k-trigger"
  class="flex items-center gap-1 p-2 opacity-60 hover:opacity-100 transition-opacity font-mono text-sm"
  aria-label="Open Command Palette"
>
  <span class="border border-current rounded px-1.5 py-0.5 opacity-70">⌘</span>
  <span class="border border-current rounded px-1.5 py-0.5 opacity-70">K</span>
</button>

<div
  id="command-palette-backdrop"
  class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm hidden flex items-start justify-center pt-[15vh] px-4"
>
  <div
    id="command-palette-modal"
    class="bg-[var(--bg-color)] w-full max-w-lg rounded-2xl shadow-[0_0_40px_rgba(0,0,0,0.2)] dark:shadow-[0_0_40px_rgba(255,255,255,0.05)] border border-gray-200 dark:border-[#222] overflow-hidden flex flex-col"
  >
    <div class="flex items-center border-b border-gray-200 dark:border-[#222] px-4 py-4">
      <Icon name="mdi:magnify" width={20} height={20} class="opacity-50" />
      <input
        type="text"
        id="command-palette-input"
        class="w-full bg-transparent border-none outline-none text-[var(--text-color)] px-4 py-1 placeholder-gray-400 dark:placeholder-gray-500 text-lg"
        placeholder="Search..."
        autocomplete="off"
      />
      <button id="command-palette-close" class="opacity-40 hover:opacity-100 transition-opacity">
        <Icon name="mdi:close" width={20} height={20} />
      </button>
    </div>
    
    <div class="max-h-[60vh] overflow-y-auto py-2" id="command-palette-results">
      <!-- Actions -->
      <div class="cmd-section">
        <div class="text-[10px] font-bold opacity-40 px-5 py-2 mt-2 uppercase tracking-widest">Actions</div>
        <div
          class="cmd-result flex items-center gap-3 px-5 py-3 cursor-pointer text-[var(--text-color)] opacity-70 hover:opacity-100 transition-all"
          data-title="toggle theme"
          data-action="theme"
        >
          <Icon name="mdi:theme-light-dark" width={18} height={18} />
          <span>Toggle Theme</span>
        </div>
      </div>

      <!-- Pages -->
      <div class="cmd-section">
        <div class="text-[10px] font-bold opacity-40 px-5 py-2 mt-2 uppercase tracking-widest">Pages</div>
        {navBarLinks.map((link) => (
          <a
            href={link.url}
            class="cmd-result flex items-center gap-3 px-5 py-3 cursor-pointer text-[var(--text-color)] opacity-70 hover:opacity-100 transition-all"
            data-title={link.title.toLowerCase()}
            data-action="link"
          >
            <Icon name="mdi:file-document-outline" width={18} height={18} />
            <span>{link.title}</span>
          </a>
        ))}
      </div>

      <!-- Social -->
      <div class="cmd-section">
        <div class="text-[10px] font-bold opacity-40 px-5 py-2 mt-2 uppercase tracking-widest">Social</div>
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            class="cmd-result flex items-center gap-3 px-5 py-3 cursor-pointer text-[var(--text-color)] opacity-70 hover:opacity-100 transition-all"
            data-title={link.title.toLowerCase()}
            data-action="link"
          >
            <Icon name={link.icon} width={18} height={18} />
            <span>{link.title}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="border-t border-gray-200 dark:border-[#222] px-5 py-3 text-xs opacity-50 flex items-center gap-2">
      <span>Use <kbd class="border border-current rounded px-1.5 py-0.5 text-[10px] uppercase">↑</kbd> <kbd class="border border-current rounded px-1.5 py-0.5 text-[10px] uppercase">↓</kbd> to navigate</span>
      <span class="mx-2">•</span>
      <span><kbd class="border border-current rounded px-1.5 py-0.5 text-[10px] uppercase">↵</kbd> to select</span>
      <span class="mx-2">•</span>
      <span><kbd class="border border-current rounded px-1.5 py-0.5 text-[10px] uppercase">ESC</kbd> to close</span>
    </div>
  </div>
</div>

<style>
  .cmd-result.active-item {
    opacity: 1 !important;
    background-color: rgba(128, 128, 128, 0.1);
  }
</style>

<script is:inline>
  const trigger = document.getElementById('cmd-k-trigger');
  const backdrop = document.getElementById('command-palette-backdrop');
  const closeBtn = document.getElementById('command-palette-close');
  const input = document.getElementById('command-palette-input');
  
  let visibleResults = [];
  let activeIndex = 0;

  function updateVisibleResults() {
    visibleResults = Array.from(document.querySelectorAll('.cmd-result')).filter(el => el.style.display !== 'none');
  }

  function renderActiveItem() {
    visibleResults.forEach((el, index) => {
      if (index === activeIndex) {
        el.classList.add('active-item');
        el.scrollIntoView({ block: 'nearest' });
      } else {
        el.classList.remove('active-item');
      }
    });
  }

  function openPalette() {
    backdrop.classList.remove('hidden');
    input.value = '';
    filterResults('');
    input.focus();
  }

  function closePalette() {
    backdrop.classList.add('hidden');
  }

  function filterResults(query) {
    const term = query.toLowerCase();
    
    document.querySelectorAll('.cmd-result').forEach(el => {
      if (el.dataset.title.includes(term)) {
        el.style.display = 'flex';
      } else {
        el.style.display = 'none';
      }
    });

    document.querySelectorAll('.cmd-section').forEach(section => {
      const hasVisibleItems = Array.from(section.querySelectorAll('.cmd-result')).some(el => el.style.display !== 'none');
      section.style.display = hasVisibleItems ? 'block' : 'none';
    });

    updateVisibleResults();
    activeIndex = 0;
    renderActiveItem();
  }

  function executeAction(el) {
    if (!el) return;
    
    if (el.dataset.action === 'theme') {
      if (typeof toggleTheme === 'function') {
        toggleTheme();
      }
      closePalette();
    } else if (el.dataset.action === 'link') {
      el.click();
      closePalette();
    }
  }

  trigger?.addEventListener('click', openPalette);
  closeBtn?.addEventListener('click', closePalette);
  
  backdrop?.addEventListener('click', (e) => {
    if (e.target === backdrop) closePalette();
  });

  input?.addEventListener('input', (e) => {
    filterResults(e.target.value);
  });

  input?.addEventListener('keydown', (e) => {
    if (visibleResults.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % visibleResults.length;
      renderActiveItem();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = (activeIndex - 1 + visibleResults.length) % visibleResults.length;
      renderActiveItem();
    } else if (e.key === 'Enter') {
      e.preventDefault();
      executeAction(visibleResults[activeIndex]);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openPalette();
    }
    if (e.key === 'Escape' && !backdrop.classList.contains('hidden')) {
      closePalette();
    }
  });

  document.querySelectorAll('.cmd-result').forEach(el => {
    el.addEventListener('mouseenter', () => {
      updateVisibleResults();
      const index = visibleResults.indexOf(el);
      if (index !== -1) {
        activeIndex = index;
        renderActiveItem();
      }
    });
    
    el.addEventListener('click', (e) => {
      if (el.dataset.action === 'theme') {
        executeAction(el);
      }
    });
  });
</script>
