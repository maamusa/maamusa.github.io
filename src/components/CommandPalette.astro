---
import { Icon } from "astro-icon/components";
import { navBarLinks, socialLinks } from "../config";
---

<button
  id="cmd-k-trigger"
  class="block p-2 opacity-60 hover:opacity-100 transition-opacity"
  aria-label="Open Command Palette"
>
  <Icon name="mdi:magnify" width={20} height={20} />
</button>

<div
  id="command-palette-backdrop"
  class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm hidden flex items-start justify-center pt-[20vh] px-4"
>
  <div
    id="command-palette-modal"
    class="bg-white dark:bg-gray-900 w-full max-w-lg rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden"
  >
    <div class="flex items-center border-b border-gray-200 dark:border-gray-700 px-4 py-3">
      <Icon name="mdi:magnify" width={20} height={20} class="text-gray-500 dark:text-gray-400" />
      <input
        type="text"
        id="command-palette-input"
        class="w-full bg-transparent border-none outline-none text-black dark:text-white px-3 py-1 placeholder-gray-400 dark:placeholder-gray-500"
        placeholder="Search pages, actions, social..."
        autocomplete="off"
      />
      <button id="command-palette-close" class="text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white">
        <Icon name="mdi:close" width={20} height={20} />
      </button>
    </div>
    
    <div class="max-h-80 overflow-y-auto pb-2" id="command-palette-results">
      <!-- Actions -->
      <div class="cmd-section">
        <div class="text-xs font-semibold text-gray-500 px-4 py-2 mt-2 uppercase tracking-wider">Actions</div>
        <div
          class="cmd-result flex items-center gap-3 px-4 py-3 mx-2 rounded-lg cursor-pointer text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          data-title="toggle theme"
          data-action="theme"
        >
          <Icon name="mdi:theme-light-dark" width={18} height={18} />
          Toggle Theme
        </div>
      </div>

      <!-- Pages -->
      <div class="cmd-section">
        <div class="text-xs font-semibold text-gray-500 px-4 py-2 mt-2 uppercase tracking-wider">Pages</div>
        {navBarLinks.map((link) => (
          <a
            href={link.url}
            class="cmd-result flex items-center gap-3 px-4 py-3 mx-2 rounded-lg cursor-pointer text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            data-title={link.title.toLowerCase()}
            data-action="link"
          >
            <Icon name="mdi:file-document-outline" width={18} height={18} />
            {link.title}
          </a>
        ))}
      </div>

      <!-- Social -->
      <div class="cmd-section">
        <div class="text-xs font-semibold text-gray-500 px-4 py-2 mt-2 uppercase tracking-wider">Social</div>
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            class="cmd-result flex items-center gap-3 px-4 py-3 mx-2 rounded-lg cursor-pointer text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            data-title={link.title.toLowerCase()}
            data-action="link"
          >
            <Icon name={link.icon} width={18} height={18} />
            {link.title}
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  /* Styling for the currently active/selected item */
  .cmd-result.active {
    background-color: rgba(156, 163, 175, 0.2); /* matches hover:bg-gray-100 / dark:hover:bg-gray-800 roughly */
  }
</style>

<script is:inline>
  const trigger = document.getElementById('cmd-k-trigger');
  const backdrop = document.getElementById('command-palette-backdrop');
  const closeBtn = document.getElementById('command-palette-close');
  const input = document.getElementById('command-palette-input');
  
  let visibleResults = [];
  let activeIndex = 0;

  function updateVisibleResults() {
    visibleResults = Array.from(document.querySelectorAll('.cmd-result')).filter(el => el.style.display !== 'none');
  }

  function renderActiveItem() {
    visibleResults.forEach((el, index) => {
      if (index === activeIndex) {
        el.classList.add('bg-gray-100', 'dark:bg-gray-800');
        // ensure element is visible in scroll container
        el.scrollIntoView({ block: 'nearest' });
      } else {
        el.classList.remove('bg-gray-100', 'dark:bg-gray-800');
      }
    });
  }

  function openPalette() {
    backdrop.classList.remove('hidden');
    input.value = '';
    filterResults('');
    input.focus();
  }

  function closePalette() {
    backdrop.classList.add('hidden');
  }

  function filterResults(query) {
    const term = query.toLowerCase();
    
    // Filter items
    document.querySelectorAll('.cmd-result').forEach(el => {
      if (el.dataset.title.includes(term)) {
        el.style.display = 'flex';
      } else {
        el.style.display = 'none';
      }
    });

    // Hide empty sections
    document.querySelectorAll('.cmd-section').forEach(section => {
      const hasVisibleItems = Array.from(section.querySelectorAll('.cmd-result')).some(el => el.style.display !== 'none');
      section.style.display = hasVisibleItems ? 'block' : 'none';
    });

    updateVisibleResults();
    activeIndex = 0; // reset selection to first item
    renderActiveItem();
  }

  function executeAction(el) {
    if (!el) return;
    
    if (el.dataset.action === 'theme') {
      if (typeof toggleTheme === 'function') {
        toggleTheme();
      }
      closePalette();
    } else if (el.dataset.action === 'link') {
      // It's an anchor tag, trigger its click
      el.click();
      closePalette();
    }
  }

  trigger?.addEventListener('click', openPalette);
  closeBtn?.addEventListener('click', closePalette);
  
  backdrop?.addEventListener('click', (e) => {
    if (e.target === backdrop) closePalette();
  });

  input?.addEventListener('input', (e) => {
    filterResults(e.target.value);
  });

  input?.addEventListener('keydown', (e) => {
    if (visibleResults.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % visibleResults.length;
      renderActiveItem();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = (activeIndex - 1 + visibleResults.length) % visibleResults.length;
      renderActiveItem();
    } else if (e.key === 'Enter') {
      e.preventDefault();
      executeAction(visibleResults[activeIndex]);
    }
  });

  // Handle global shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openPalette();
    }
    if (e.key === 'Escape' && !backdrop.classList.contains('hidden')) {
      closePalette();
    }
  });

  // Handle mouse hover setting active item
  document.querySelectorAll('.cmd-result').forEach(el => {
    el.addEventListener('mouseenter', () => {
      updateVisibleResults();
      const index = visibleResults.indexOf(el);
      if (index !== -1) {
        activeIndex = index;
        renderActiveItem();
      }
    });
    
    el.addEventListener('click', (e) => {
      // Only intercept click if it's the theme action, otherwise let anchor tags behave normally
      if (el.dataset.action === 'theme') {
        executeAction(el);
      }
    });
  });
</script>
