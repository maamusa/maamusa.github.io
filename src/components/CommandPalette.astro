---
import { Icon } from "astro-icon/components";
import { navBarLinks } from "../config";
---

<button
  id="cmd-k-trigger"
  class="block p-2 opacity-60 hover:opacity-100 transition-opacity"
  aria-label="Open Command Palette"
>
  <Icon name="mdi:magnify" width={20} height={20} />
</button>

<div
  id="command-palette-backdrop"
  class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm hidden flex items-start justify-center pt-[20vh] px-4"
>
  <div
    id="command-palette-modal"
    class="bg-gray-800 dark:bg-gray-900 w-full max-w-lg rounded-xl shadow-2xl border border-gray-700 overflow-hidden"
  >
    <div class="flex items-center border-b border-gray-700 px-4 py-3">
      <Icon name="mdi:magnify" width={20} height={20} class="text-gray-400" />
      <input
        type="text"
        id="command-palette-input"
        class="w-full bg-transparent border-none outline-none text-white px-3 py-1 placeholder-gray-500"
        placeholder="Type a command or search..."
        autocomplete="off"
      />
      <button id="command-palette-close" class="text-gray-400 hover:text-white">
        <Icon name="mdi:close" width={20} height={20} />
      </button>
    </div>
    
    <div class="p-2 max-h-80 overflow-y-auto" id="command-palette-results">
      <div class="text-xs font-semibold text-gray-500 px-3 py-2 uppercase tracking-wider">Navigation</div>
      {navBarLinks.map((link) => (
        <a
          href={link.url}
          class="cmd-result flex items-center gap-3 px-3 py-3 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors"
          data-title={link.title.toLowerCase()}
        >
          <Icon name="mdi:file-document-outline" width={18} height={18} />
          {link.title}
        </a>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  const trigger = document.getElementById('cmd-k-trigger');
  const backdrop = document.getElementById('command-palette-backdrop');
  const closeBtn = document.getElementById('command-palette-close');
  const input = document.getElementById('command-palette-input');
  const results = document.querySelectorAll('.cmd-result');

  function openPalette() {
    backdrop.classList.remove('hidden');
    input.value = '';
    filterResults('');
    input.focus();
  }

  function closePalette() {
    backdrop.classList.add('hidden');
  }

  function filterResults(query) {
    const term = query.toLowerCase();
    results.forEach(el => {
      if (el.dataset.title.includes(term)) {
        el.style.display = 'flex';
      } else {
        el.style.display = 'none';
      }
    });
  }

  trigger?.addEventListener('click', openPalette);
  closeBtn?.addEventListener('click', closePalette);
  
  backdrop?.addEventListener('click', (e) => {
    if (e.target === backdrop) closePalette();
  });

  input?.addEventListener('input', (e) => {
    filterResults(e.target.value);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openPalette();
    }
    if (e.key === 'Escape' && !backdrop.classList.contains('hidden')) {
      closePalette();
    }
  });
</script>
