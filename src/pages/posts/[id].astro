---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { identity } from "../../config";
import PostControls from "../../components/PostControls.astro";
import Comments from "../../components/Comments.astro";
import ReactionButtons from "../../components/ReactionButtons.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
---

<Layout
  seo={{
    title: entry.data.title,
    description: entry.data.description,
    image: entry.data.image ? entry.data.image.url : "/assets/posts/default-cat.png",
  }}
>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-4">{entry.data.title}</h1>
    <p class="opacity-60 mb-6">
      {entry.data.description}
    </p>
    <div class="flex gap-4 mb-6">
      <Image
        src={identity.logo}
        alt={identity.name}
        width={40}
        height={40}
        class="w-[40px] aspect-square object-cover rounded-full"
      />
      <div class="flex-1 min-w-0">
        <p class="font-medium">{identity.name}</p>
        <div class="flex items-center justify-between w-full">
          <p class="opacity-60">
            {entry.data.pubDate.toLocaleDateString()} · {
              remarkPluginFrontmatter.minutesRead
            }
          </p>
          <div class="flex items-center gap-2">
            <PostControls />
            <ReactionButtons pageId={entry.id} />
          </div>
        </div>
      </div>
    </div>

    <article
      class="prose prose-invert prose-a:text-blue-300 prose-a:underline-offset-4 prose-headings:mb-2 prose-p:text-[#b3b3b3]"
    >
      <Content />
    </article>
    
    <Comments pageId={entry.id} pageUrl={`https://maamusa.co/posts/${entry.id}`} pageTitle={entry.data.title} />
  </section>
</Layout>
