---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import { Icon } from "astro-icon/components";
import { homePageContent } from "../config";
import { getCollection } from "astro:content";

const posts = await getCollection("posts");
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(3)
---

<Layout seo={homePageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <div class="flex items-center gap-2 mb-4">
      <p class="text-sm italic opacity-50">IPA /mɑː jɑːŋk mʊˈsɑːdi/ — moon, calmness</p>
      <button id="pronounce-btn" class="opacity-50 hover:opacity-100 transition-opacity" aria-label="Pronounce name">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-volume-2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
      </button>
    </div>
    <div class="mb-6 mt-6 min-h-[4rem] sm:min-h-[3rem]">
      <h2 class="font-bold text-xl sm:text-2xl mb-2">
        I teach machines how to think so humans can do less.
      </h2>
      <p class="text-sm opacity-60">Senior AI Engineer @ Google.</p>
    </div>
    
    <div class="prose prose-invert prose-p:text-[#b3b3b3] prose-a:text-blue-300 prose-a:underline-offset-4 mb-6">
      <p>
        Welcome to my corner of the internet. By day, I build fast minds. Off the clock, I am usually traveling, playing one of <span class="group relative inline-block cursor-pointer border-b border-dotted border-transparent hover:border-black/50 dark:hover:border-white/50 hover:text-black dark:hover:text-white transition-colors">three instruments<span class="absolute bottom-full left-1/2 -translate-x-1/2 pb-2 hidden group-hover:flex items-end z-10"><a href="https://www.youtube.com/@mayankmusaddi3959" target="_blank" class="relative flex items-center gap-2 bg-white dark:bg-zinc-800 hover:bg-gray-100 dark:hover:bg-zinc-700 transition-colors px-3 py-2 rounded-md shadow-xl border border-gray-200 dark:border-zinc-700 whitespace-nowrap !no-underline"><span class="text-xl">🎹</span><span class="text-xl">🥁</span><span class="text-xl">🎸</span><span class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-white dark:border-t-zinc-800"></span></a></span></span>, or writing. This site is where I document my thoughts on AI <span class="group relative inline-block border-b border-dotted border-transparent hover:border-black/50 dark:hover:border-white/50 hover:text-black dark:hover:text-white transition-colors"><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC9356536/" target="_blank" class="!text-inherit !no-underline relative z-0">research</a><span class="absolute bottom-full left-1/2 -translate-x-1/2 pb-2 hidden group-hover:flex items-end z-10"><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC9356536/" target="_blank" class="relative flex items-center gap-2 bg-white dark:bg-zinc-800 hover:bg-gray-100 dark:hover:bg-zinc-700 transition-colors px-3 py-2 rounded-md shadow-xl border border-gray-200 dark:border-zinc-700 whitespace-nowrap text-black dark:text-white !no-underline"><Icon name="mdi:rice" class="w-5 h-5 text-blue-500 dark:text-blue-300" /><span class="text-sm font-medium">Read Paper</span><span class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-white dark:border-t-zinc-800"></span></a></span></span>, philosophy, and whatever rabbit hole I've fallen down recently.
      </p>
    </div>
    
    <p class="text-sm opacity-60 mb-8 flex flex-wrap items-center gap-x-1">
      Send me a <a href="mailto:musaddi97@gmail.com" class="text-blue-300 hover:underline underline-offset-4">message</a> if you’d like to chat. I’m also available on 
      <a href="https://www.linkedin.com/in/musaddi" target="_blank" aria-label="LinkedIn" class="hover:text-blue-300 transition-colors mx-0.5"><Icon name="mdi:linkedin" class="w-5 h-5 inline translate-y-[-1px]" /></a>.
    </p>

    <div class="flex items-center gap-4 group w-fit mb-8">
      {
        homePageContent.links.map((link) => (
          <Link text={link.title} href={link.url} external={link.external} />
        ))
      }
    </div>

    <script>
      document.getElementById('pronounce-btn')?.addEventListener('click', () => {
        const utterance = new SpeechSynthesisUtterance('Maa Yaahnk Musaddi');
        utterance.lang = 'en-IN';
        utterance.rate = 0.85;
        window.speechSynthesis.speak(utterance);
      });
    </script>
  </section>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <h2 class="mb-8 font-bold">Latest Posts</h2>
    <div class="grid grid-cols-1 gap-10 sm:gap-6 mb-10">
      {
        posts.map((post) => (
          <a
            href={post.data.external_url ? post.data.external_url : `/posts/${post.id}`}
            target={post.data.external_url ? "_blank" : "_self"}
            class="group block w-full post"
          >
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between w-full gap-2 sm:gap-4">
              <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                <h3 class="font-bold group-hover:underline underline-offset-4">{post.data.title}</h3>
                <div class="flex flex-wrap gap-1">
                  {(post.data.tags || []).map((tag: string) => (
                    <span class="text-[10px] px-1.5 py-0.5 bg-black/5 dark:bg-white/5 rounded border border-black/10 dark:border-white/10 opacity-70">{tag}</span>
                  ))}
                </div>
              </div>
              <p class="opacity-60 text-sm whitespace-nowrap">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </p>
            </div>
            <p class="text-sm opacity-60 mt-1 line-clamp-2">{post.data.description}</p>
          </a>
        ))
      }
    </div>
    <div class="text-center">
      <a
        href="/posts"
        class="underline underline-offset-4 opacity-60 hover:opacity-100 transition-opacity"
        >View all</a
      >
    </div>
  </section>


</Layout>
