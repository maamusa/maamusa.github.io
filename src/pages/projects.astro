---
import Layout from "../layouts/Layout.astro";
import { projectPageContent } from "../config";
import ProjectCard from "../components/ProjectCard.astro";
---

<Layout seo={projectPageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-1">Projects</h1>
    <p class="opacity-60 mb-10">{projectPageContent.subtitle}</p>
    <div class="grid grid-cols-1 group">
      {
        projectPageContent.projects.map((project: any) => (
          <ProjectCard {...project} />
        ))
      }
    </div>
  </section>
</Layout>
