---
import Layout from "../layouts/Layout.astro";
import { projectPageContent } from "../config";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<Layout seo={projectPageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-1">Projects</h1>
    <p class="opacity-60 mb-10">{projectPageContent.subtitle}</p>
    <div class="grid grid-cols-1 group">
      {
        projects.map((project) => (
          <ProjectCard title={project.data.title} description={project.data.description} image={project.data.image?.url || ""} url={`/projects/${project.id}`} year={project.data.pubDate.getFullYear().toString()} />
        ))
      }
    </div>
  </section>
</Layout>
