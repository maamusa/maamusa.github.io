---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
				list-style: none;
				padding: 0;
			}
			.projects-grid li {
				display: flex;
			}
			.projects-grid a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				width: 100%;
			}
			.title {
				margin: 0;
				font-size: 1.5rem;
				color: var(--text-primary);
				transition: color 0.2s ease;
			}
			.projects-grid a:hover .title {
				color: var(--accent);
			}
			.description {
				margin-top: 0.5rem;
				color: var(--text-secondary);
				font-size: 0.95rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="gradient-text">My Projects</h1>
			<p>A collection of my academic, open-source, and personal projects.</p>
			<ul class="projects-grid">
				{
					projects.map((project) => (
						<li>
							<a href={`/projects/${project.id}/`} class="card">
								<h4 class="title">{project.data.title}</h4>
								<p class="description">{project.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
